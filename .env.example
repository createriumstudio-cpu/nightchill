# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# Site URL (for OGP and canonical links)
NEXT_PUBLIC_SITE_URL=https://www.futatabito.com

# Google Places API (Phase 1)
# 未設定の場合はフォールバックデータが使用されます
GOOGLE_PLACES_API_KEY=

# Google Maps Directions API (Phase 1)
# 未設定の場合はテキスト案内にフォールバック
GOOGLE_MAPS_API_KEY=

# Contextual PR (文脈連動型広告)
# "true" でPR挿入を有効化（デフォルトはOFF）
CONTEXTUAL_PR_ENABLED=false

# NextAuth.js (Google OAuth)
# Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client IDs
# Authorized redirect URIs: http://localhost:3000/api/auth/callback/google (dev), https://www.futatabito.com/api/auth/callback/google (prod)
AUTH_SECRET=  # openssl rand -base64 32 で生成
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Search Console verification
# Search Console > Settings > Ownership verification > HTML tag のcontentの値を設定
GOOGLE_SITE_VERIFICATION=

# Stripe (プレミアムサブスクリプション)
# 未設定の場合は課金機能が無効化されます（graceful degradation）
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...  # 月額480円のPrice ID

# OpenWeatherMap API (optional - for weather integration)
